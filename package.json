{
  "name": "electron-native-share",
  "version": "0.1.0",
  "description": "Universal native Share API for Electron apps — macOS NSSharingService, Windows WinRT DataTransferManager",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js"
    }
  },
  "files": [
    "lib/",
    "src/darwin/",
    "src/win32/",
    "binding.gyp",
    "prebuilds/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:ts": "tsc",
    "build:native": "node-gyp rebuild",
    "build": "npm run build:ts && npm run build:native",
    "install": "node-gyp-build || exit 0",
    "prebuildify": "prebuildify --napi --strip",
    "prepublishOnly": "npm run build:ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf lib build prebuilds"
  },
  "keywords": [
    "electron",
    "share",
    "native",
    "napi",
    "macos",
    "windows",
    "share-sheet",
    "NSSharingService",
    "WinRT"
  ],
  "author": "Pedro Primor <pedro.primor@pm.me> (https://github.com/pprimor)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pprimor/electron-native-share.git"
  },
  "homepage": "https://github.com/pprimor/electron-native-share#readme",
  "bugs": {
    "url": "https://github.com/pprimor/electron-native-share/issues"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "node-addon-api": "^8.3.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "node-gyp": "^11.1.0",
    "prebuildify": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "electron": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  }
}
